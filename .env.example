APP_ENV=development
VITE_API_BASE_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174","http://localhost:5175","http://127.0.0.1:5175"]
# Production: set to your actual frontend origin(s).  When set, only these
# origins are allowed and credentials are enabled.  Leave empty in development
# to fall back to CORS_ORIGINS above.
CORS_ALLOWED_ORIGINS=
RESEARCH_API_KEY=

RESEARCH_DB_PATH=.data/research.sqlite3
RESEARCH_ARTIFACT_DIR=.data/research-runs
FORECAST_ENABLED=true
FORECAST_ARTIFACT_DIR=.data/forecast-runs
FORECAST_MAX_CONCURRENT_PACKS=1
RESEARCH_POLLER_ENABLED=true
RESEARCH_POLLER_INTERVAL_SECONDS=5
RESEARCH_DEEP_RESEARCH_TIMEOUT_SECONDS=7200
RESEARCH_DEEP_RESEARCH_SUBMIT_TIMEOUT_SECONDS=120
RESEARCH_DEEP_RESEARCH_SUBMIT_STALE_SECONDS=300
RESEARCH_DEEP_RESEARCH_COLLECTING_STALE_SECONDS=60
RESEARCH_REVIEW_TIMEOUT_SECONDS=180
RESEARCH_REVIEW_MAX_REPORT_CHARS=50000
RESEARCH_REVIEW_MAX_CITATIONS=40
RESEARCH_REVIEW_WEB_SEARCH_ENABLED=false
RESEARCH_PRIVATE_VECTOR_STORE_ALLOWLIST=[]
RESEARCH_MANUAL_IMPORT_MAX_REPORT_CHARS=50000
RESEARCH_MANUAL_IMPORT_MAX_FILE_BYTES=1048576
RESEARCH_LIVE_API_TESTS=0
DEFAULT_MAX_TARGETED_RERUN_RUNS=2
DEFAULT_MAX_FULL_RERUN_RUNS=1
DEFAULT_MAX_LLM_PATCH_RUNS=3
DEFAULT_MAX_VERIFICATION_RUNS=3
DEFAULT_MAX_TOTAL_ITERATIONS=5
DEFAULT_MAX_TOTAL_TOOL_CALLS=120
# Azure OpenAI Standard Global pricing in USD per 1M tokens.
# o3-deep-research: input $10, output $40.
RESEARCH_DEEP_RESEARCH_INPUT_COST_PER_1M=10
RESEARCH_DEEP_RESEARCH_OUTPUT_COST_PER_1M=40
# GPT-5.5: input $5, output $30.
RESEARCH_REVIEWER_INPUT_COST_PER_1M=5
RESEARCH_REVIEWER_OUTPUT_COST_PER_1M=30
RESEARCH_WEB_SEARCH_COST_PER_CALL=0.01

O3_DEEP_RESEARCH_AZURE_OPENAI_ENDPOINT=
O3_DEEP_RESEARCH_AZURE_OPENAI_KEY=
O3_DEEP_RESEARCH_AZURE_OPENAI_API_VERSION=
O3_DEEP_RESEARCH_AZURE_OPENAI_DEPLOYMENT_NAME=

GPT5_5_AZURE_OPENAI_ENDPOINT=
GPT5_5_AZURE_OPENAI_KEY=
GPT5_5_AZURE_OPENAI_API_VERSION=
GPT5_5_AZURE_OPENAI_DEPLOYMENT_NAME=

GPT5_4_MINI_AZURE_OPENAI_ENDPOINT=
GPT5_4_MINI_AZURE_OPENAI_KEY=
GPT5_4_MINI_AZURE_OPENAI_API_VERSION=
GPT5_4_MINI_AZURE_OPENAI_DEPLOYMENT_NAME=
